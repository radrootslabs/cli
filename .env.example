# Copy to .env for local CLI development; the CLI loads .env by default from the repo root.
RADROOTS_CLI_PATHS_PROFILE=repo_local
RADROOTS_CLI_PATHS_REPO_LOCAL_ROOT=infra/local/runtime/radroots
RADROOTS_CLI_OUTPUT_FORMAT=terminal
RADROOTS_CLI_LOGGING_FILTER=info
RADROOTS_CLI_LOGGING_OUTPUT_DIR=infra/local/runtime/radroots/logs/apps/cli
RADROOTS_CLI_LOGGING_STDOUT=false
RADROOTS_CLI_ACCOUNT_SECRET_BACKEND=encrypted_file
RADROOTS_CLI_ACCOUNT_SECRET_FALLBACK=none
